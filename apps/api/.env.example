PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/recall

# Auth0 (same tenant as web app; create API and set identifier as AUTH0_AUDIENCE)
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_AUDIENCE=

# Allowed web origin for CORS
WEB_ORIGIN=http://localhost:3000

# Cloudflare R2 (resume storage). Create bucket and API token in Cloudflare dashboard.
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=recall-resumes
