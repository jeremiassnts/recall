# Auth0 (create app at https://manage.auth0.com)
# Enable Google connection in Auth0 Dashboard
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional: Auth0 API audience (create API in Auth0 for backend JWT validation)
# If set, use same value as AUTH0_AUDIENCE in apps/api
# AUTH0_AUDIENCE=https://api.recall.app

# Backend URL (for server-side sync call)
API_URL=http://localhost:4000
